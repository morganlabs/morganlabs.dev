---
import HorizontalLinks from "@components/HorizontalLinks.astro";

type Page = {
    title: string;
    href: string;
    enabled: boolean;
};

type Props = {
    active_route: `/${string}`;
    pages?: Page[];
};

let {
    active_route,
    pages = [
        { title: "Home", href: "/", enabled: true },
        { title: "About", href: "/about/@morganlabs", enabled: true },
        { title: "Blog", href: "/blog/page/1", enabled: true },
        { title: "Portfolio", href: "/portfolio", enabled: false },
    ],
} = Astro.props;

const filtered_pages = pages
    .filter((p) => p.enabled)
    .map(({ title, href }) => ({
        title,
        href,
        custom_class: [href === active_route ? "active" : ""],
    }));
---

<nav class="navbar">
    <div class="container">
        <HorizontalLinks links={filtered_pages} />
        <a href="mailto:mjones@morganlabs.dev" class="email"
            >mjones@morganlabs.dev</a
        >
    </div>
</nav>

<style lang="scss">
    .container {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        grid-template-rows: 5rem;
        align-items: center;
        max-width: calc($content-width + 1rem);
        font-family: $body-font;
        padding-inline: 1rem;
        margin-inline: auto;

        :global(.links .link-container:not(.active) .link) {
            text-decoration: none;
        }
    }

    .email {
        color: $white;
        justify-self: flex-end;
    }

    @media (max-width: 574px) {
        .container {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(2, 2rem);
            gap: 0.5rem;
            place-items: center;
            padding-block: 0.5rem;
        }

        .email {
            justify-self: center;
        }
    }
</style>
